# ============================================================
# Damrongdham DCMS — Environment Variables (Docker Compose)
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าก่อนรัน:
#   cp .env.example .env

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=damrongdham_db
MYSQL_USER=damrongdham_user
MYSQL_PASSWORD=your_password_here

# JWT (Backend)
# ควรเปลี่ยนเป็น random string อย่างน้อย 64 ตัวอักษรใน Production
JWT_SECRET=your_jwt_secret_change_to_random_64_chars_in_production

# CORS (Backend)
CORS_ORIGIN=http://localhost:5173
