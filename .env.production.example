# ============================================================
# Production env (On-premise / Ubuntu) — คัดลอกเป็น .env.production แล้วแก้ค่า
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
# ⚠️ ห้าม commit .env.production (อยู่ใน .gitignore)
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
MYSQL_DATABASE=damrongdham_db
MYSQL_USER=damrongdham_user
MYSQL_PASSWORD=change_me_strong_password

# --- Backend / Auth ---
JWT_SECRET=change_me_random_64_chars
JWT_EXPIRES_IN=8h

# --- CORS ---
# ใส่ domain จริงของ server เช่น http://damrongdham.sisaket.go.th
# บน Railway ตั้งค่าใน Dashboard แทน (frontend serve by same Express — same-origin, CORS optional)
CORS_ORIGIN=http://localhost:5001

# หมายเหตุ: บน Railway ไม่ใช้ไฟล์นี้ — ตั้งค่า env vars ใน Railway Dashboard แทน
