# Environment variables
.env
.env.production
.env.*.local

# Nginx SSL certificates (on-premise) — ignore cert files, keep directory structure
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key

# Node modules
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/
frontend/build/
backend/public/

# File uploads (runtime)
backend/uploads/*
!backend/uploads/.gitkeep

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Docker data volumes
mysql-data/
