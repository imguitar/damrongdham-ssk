# ============================================================
# Damrongdham DCMS — Backend Environment Variables
# ============================================================
# สำหรับรัน Backend แบบ standalone หรือใช้เป็น reference สำหรับ Production
# ใน Docker Dev ใช้ environment ใน docker-compose.yml แทน

# Server
NODE_ENV=development
PORT=5001

# MySQL
DB_HOST=db
DB_PORT=3306
DB_USER=damrongdham_user
DB_PASSWORD=your_password_here
DB_NAME=damrongdham_db

# JWT
JWT_SECRET=your_jwt_secret_change_to_random_64_chars_in_production
JWT_EXPIRES_IN=8h

# File Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:5173
