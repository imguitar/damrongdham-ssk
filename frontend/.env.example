# ============================================================
# Damrongdham DCMS — Frontend Environment Variables
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่า:
#   cp .env.example .env

# Backend API URL
# Dev:  http://localhost:5001/api
# Prod: /api  (same-origin, Express serve frontend เอง)
VITE_API_BASE_URL=http://localhost:5001/api

# App Title (แสดงใน Browser Tab)
VITE_APP_TITLE=ศูนย์ดำรงธรรมจังหวัดศรีสะเกษ (Dev)
